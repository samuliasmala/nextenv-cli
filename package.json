    "dotenv-cli",
    "env",
    "cli",
    "@next/env"
  ],
  "license": "MIT",
  "author": "Samuli Asmala",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samuliasmala/nextenv-cli.git"
  },
  "bugs": {
    "url": "https://github.com/samuliasmala/nextenv-cli/issues"
  },
  "homepage": "https://github.com/samuliasmala/nextenv-cli#readme",
